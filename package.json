{
  "name": "@dheeraj-pilakkat/uiaudit.js",
  "version": "2.1.0",
  "description": "A CLI and VS Code extension to audit React and Next.js components for accessibility, performance, and SEO issues.",
  "keywords": [
    "react",
    "next.js",
    "accessibility",
    "performance",
    "seo",
    "audit",
    "static-analysis",
    "typescript"
  ],
  "license": "MIT",
  "author": "Dheeraj p",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "uiaudit": "dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dheeraj-pilakkat/UiAudit.js.git"
  },
  "bugs": {
    "url": "https://github.com/Dheeraj-pilakkat/UiAudit.js/issues"
  },
  "homepage": "https://github.com/Dheeraj-pilakkat/UiAudit.js#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsc",
    "vscode:package": "cd vscode-extension && npx --yes @vscode/vsce package --no-dependencies --out ../uiaudit-vscode-2.1.0.vsix",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm test",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@babel/types": "^7.29.7",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.125.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^1.5.0"
  }
}
